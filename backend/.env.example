# DevisPro CI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

PORT=3000
FRONTEND_URL=https://devispro-ci.netlify.app

# PostgreSQL (Render ou autre)
DATABASE_URL=postgresql://user:password@host:5432/devispro

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Wave CI (optionnel MVP)
WAVE_API_KEY=your_wave_api_key_here
WAVE_MERCHANT_ID=your_merchant_id
